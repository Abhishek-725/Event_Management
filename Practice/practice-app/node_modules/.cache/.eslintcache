         </input> \r\n                {errors.name && <span className='errorMsg'>* {errors.name.message} </span>} \r\n                <br/> <br/>\r\n\r\n                <input type=\"email\" placeholder='Enter e-mail...'\r\n                {...register(\"email\",{required:{value:true,message:\"E-mail is Required!\"},\r\n                pattern:{\r\n                        value: /^[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}$/i,\r\n                        message: \"Invalid email address!\"\r\n                    }\r\n                \r\n                })}>\r\n                </input>\r\n                {errors.email && <span className='errorMsg'>*{errors.email.message}</span>}\r\n                <br/> <br/>       \r\n                {/* <PasswordToggle /> */}\r\n\r\n                <button>SUBMIT</button>\r\n            </form>\r\n            \r\n        </>\r\n     );\r\n\r\n}\r\nfunction display(moviearr) {\r\n    const result = moviearr.map((name , index) => <li key={index}>{name}</li>);   \r\n    return  result; \r\n  }\r\n\r\nexport default Home;","C:\\React_JS\\Practice\\practice-app\\src\\MovieComponent\\PasswordToggle.jsx",[],[],"C:\\React_JS\\Practice\\practice-app\\src\\PracticeComponent\\User.jsx",["31","32"],[],{"ruleId":"33","severity":1,"message":"34","line":3,"column":8,"nodeType":"35","messageId":"36","endLine":3,"endColumn":12},{"ruleId":"33","severity":1,"message":"37","line":4,"column":8,"nodeType":"35","messageId":"36","endLine":4,"endColumn":22},{"ruleId":"33","severity":1,"message":"38","line":2,"column":20,"nodeType":"35","messageId":"36","endLine":2,"endColumn":25},{"ruleId":"33","severity":1,"message":"39","line":3,"column":10,"nodeType":"35","messageId":"36","endLine":3,"endColumn":22},{"ruleId":"33","severity":1,"message":"37","line":6,"column":8,"nodeType":"35","messageId":"36","endLine":6,"endColumn":22},{"ruleId":"33","severity":1,"message":"40","line":23,"column":11,"nodeType":"35","messageId":"36","endLine":23,"endColumn":26},{"ruleId":"3